# IP máy chạy server (ipconfig → IPv4, ví dụ 192.168.0.107)
EXPO_PUBLIC_API_IP=192.168.0.107
EXPO_PUBLIC_API_PORT=4000

# Ghi đè URL đầy đủ (tùy chọn)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.107:4000

# Chỉ bật khi chạy Android emulator (không dùng trên máy thật)
# EXPO_PUBLIC_USE_EMULATOR=true
